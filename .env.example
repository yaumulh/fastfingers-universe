# Local SQLite (default quick dev)
# DATABASE_URL="file:./dev.db"

# Phase 2+ recommended (PostgreSQL)
# DATABASE_URL = pooled/runtime URL (for app queries)
# DIRECT_URL = direct/non-pooled URL (for migrations / db push)
# DATABASE_URL="postgresql://USER:PASSWORD@POOL_HOST:5432/DBNAME?sslmode=require&schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/DBNAME?sslmode=require&schema=public"

# Redis for shared cache + shared rate-limit + Socket adapter
# Use rediss:// if your provider requires TLS (Railway usually does)
# REDIS_URL="rediss://default:PASSWORD@HOST:6379"

# App URL for socket CORS
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Session signing secret (set a long random string in production)
# AUTH_SIGNING_SECRET="replace-with-long-random-secret"

# Optional email verification sender (Resend)
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="Fast-fingers Universe <no-reply@yourdomain.com>"

# Optional secret for cron endpoint:
# POST /api/internal/competitions/finalize
# Header: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET="replace-with-random-secret"

# Optional custom socket port
# SOCKET_PORT=3001
